# GHCR image references — set these to your actual GitHub username/org after first push
# e.g. ghcr.io/your-github-username/cville-rag/backend:latest
BACKEND_IMAGE=ghcr.io/your-github-username/cville-rag/backend:latest
FRONTEND_IMAGE=ghcr.io/your-github-username/cville-rag/frontend:latest

# Required: OpenRouter API key for LLM inference
# Get yours at https://openrouter.ai
OPENROUTER_API_KEY=sk-or-...

# Optional: HuggingFace token (only needed for gated models)
HF_TOKEN=hf_...

# Optional: public URL of your site (sent as HTTP-Referer to OpenRouter)
SITE_URL=https://yourdomain.com

# Set to true for local development (disables HTTPS redirect enforcement)
# Set to false (or omit) in production — requires a reverse proxy that sets x-forwarded-proto
DEV_MODE=false
